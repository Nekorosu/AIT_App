<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AIT_App.AuthWindow"
        Title="AIT_App — Вход"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <!-- ДИЗАЙНЕР: файл рядом с .axaml.cs — требование Avalonia для генерации полей; при смене x:Name согласуйте с кодом. -->
    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Электронный журнал"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="ConnectionStatusText"
                           Text="Проверка соединения..."
                           VerticalAlignment="Center" />
                <Image x:Name="ConnectionIcon"
                       Width="20"
                       Height="20"
                       IsVisible="False" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="Логин" />
            <ComboBox x:Name="LoginCombo"
                      IsEditable="False"
                      PlaceholderText="Выберите логин" />
            <TextBlock Text="Пароль" />
            <TextBox x:Name="PasswordInput"
                     PasswordChar="*"
                     Watermark="Введите пароль" />
        </StackPanel>

        <Button x:Name="LoginButton"
                Grid.Row="2"
                Content="Вход"
                HorizontalAlignment="Stretch"
                IsEnabled="False" />
    </Grid>
</Window>
