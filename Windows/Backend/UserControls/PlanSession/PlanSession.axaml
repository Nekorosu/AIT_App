<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIT_App.PlanSession">
    <!-- ДИЗАЙНЕР: форма слева, таблица справа; разметка рядом с PlanSession.axaml.cs (Avalonia).
         Добавлено: «Изменить выбранное» + панель режима редактирования. -->
    <Grid ColumnDefinitions="320,*" ColumnSpacing="12">
        <Border Grid.Column="0" Padding="12" CornerRadius="8" Background="White">
            <StackPanel Spacing="10">
                <TextBlock Text="Планирование сессии" FontWeight="SemiBold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Предмет" />
                    <ComboBox x:Name="SubjectCombo" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Дата сессии" />
                    <CalendarDatePicker x:Name="SessionDatePicker" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="BtnAdd" Content="Добавить" />
                    <Button x:Name="BtnEdit" Content="Изменить выбранное" />
                    <Button x:Name="BtnDelete" Content="Удалить выбранное" />
                </StackPanel>

                <!-- Появляется в режиме редактирования (выбрали строку → кнопка «Изменить») -->
                <Border x:Name="EditModeBar"
                        Padding="8"
                        CornerRadius="6"
                        Background="#fff7e6"
                        IsVisible="False">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Режим редактирования"
                                   FontWeight="SemiBold"
                                   Foreground="#a06000" />
                        <TextBlock x:Name="EditModeStatus"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BtnSaveEdit" Content="Сохранить" Classes="accent" />
                            <Button x:Name="BtnCancelEdit" Content="Отмена" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- После добавления/удаления вызывается sp_UpdateGradeTypes() для пересчёта типов оценок. -->
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="12" CornerRadius="8" Background="White">
            <DataGrid x:Name="SessionsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column" />
        </Border>
    </Grid>
</UserControl>
