<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIT_App.Reports">
    <!-- ДИЗАЙНЕР: вкладки и счётчики; разметка рядом с Reports.axaml.cs (Avalonia). -->
    <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="0,0,0,8">
        <Border Padding="12" CornerRadius="8" Background="White">
            <Grid ColumnDefinitions="*,*,*,Auto,Auto" ColumnSpacing="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Специальность" />
                    <ComboBox x:Name="SpecialityCombo" PlaceholderText="Все" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Группа" />
                    <ComboBox x:Name="GroupCombo" PlaceholderText="Все" IsEnabled="False" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Тип оценки" />
                    <ComboBox x:Name="TypeCombo" />
                </StackPanel>
                <Button x:Name="BtnBuild"
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Content="Построить" />
                <Button x:Name="BtnExport"
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Content="Экспорт (5 листов)" />
            </Grid>
        </Border>

        <TabControl x:Name="Tabs" Grid.Row="1">
            <TabItem Header="Отличники">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock x:Name="CntExcellent" Margin="0,0,0,6" />
                    <DataGrid x:Name="GridExcellent"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All" />
                </Grid>
            </TabItem>
            <TabItem Header="Хорошисты">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock x:Name="CntGood" Margin="0,0,0,6" />
                    <DataGrid x:Name="GridGood"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All" />
                </Grid>
            </TabItem>
            <TabItem Header="Троечники">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock x:Name="CntThree" Margin="0,0,0,6" />
                    <DataGrid x:Name="GridThree"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All" />
                </Grid>
            </TabItem>
            <TabItem Header="Должники">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock x:Name="CntDebt" Margin="0,0,0,6" />
                    <DataGrid x:Name="GridDebt"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All" />
                </Grid>
            </TabItem>
            <TabItem Header="Красный диплом">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock x:Name="CntRed" Margin="0,0,0,6" />
                    <DataGrid x:Name="GridRed"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="All" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
