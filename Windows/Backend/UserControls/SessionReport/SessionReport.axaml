<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AIT_App.SessionReport">
    <!-- ДИЗАЙНЕР: два грида + панель правки выделенной оценки;
         разметка рядом с SessionReport.axaml.cs (Avalonia). -->
    <Grid RowDefinitions="Auto,Auto,*,Auto,*" RowSpacing="10" Margin="0,0,0,8">
        <!-- Row 0: фильтры -->
        <Border Grid.Row="0" Padding="12" CornerRadius="8" Background="White">
            <Grid ColumnDefinitions="*,*,*,*,Auto" ColumnSpacing="8" RowDefinitions="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Группа" />
                    <ComboBox x:Name="GroupCombo" PlaceholderText="Группа" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Дата с" />
                    <CalendarDatePicker x:Name="DateFromPicker" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Дата по" />
                    <CalendarDatePicker x:Name="DateToPicker" />
                </StackPanel>
                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <TextBlock Text="" />
                </StackPanel>
                <Button x:Name="BtnShow"
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Content="Показать отчёт" />
            </Grid>
        </Border>

        <!-- Row 1: панель редактирования выделенной оценки -->
        <Border x:Name="EditPanel"
                Grid.Row="1"
                Padding="12"
                CornerRadius="8"
                Background="#e6f4ff"
                IsVisible="False">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock x:Name="EditPanelStatus"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="Кликните по ячейке с оценкой, чтобы изменить или удалить её." />
                <ComboBox x:Name="EditGradeCombo"
                          Grid.Column="1"
                          Width="80"
                          VerticalAlignment="Center"
                          PlaceholderText="Оценка" />
                <Button x:Name="BtnSaveEdit"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="Изменить"
                        IsEnabled="False" />
                <Button x:Name="BtnDeleteSelected"
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Content="Удалить"
                        IsEnabled="False" />
                <Button x:Name="BtnCancelSelection"
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        Content="Отмена" />
            </Grid>
        </Border>

        <!-- Row 2: pivot оценок -->
        <DataGrid x:Name="GradesGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column" />

        <!-- Row 3: заголовок + экспорт -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Успеваемость по предметам" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button x:Name="BtnExport" Content="Экспорт в Excel" />
        </StackPanel>

        <!-- Row 4: грид успеваемости -->
        <DataGrid x:Name="PerfGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column" />
    </Grid>
</UserControl>
